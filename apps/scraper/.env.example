# Scraper source: "ndl" (国会) or "local" (地方議会)
SCRAPER_SOURCE=ndl

# NDL scraper: date range in YYYY-MM format
SCRAPER_FROM=2024-01
SCRAPER_UNTIL=2024-03

# Local scraper: at least one of these is required
# SCRAPER_PREFECTURE=東京都
# SCRAPER_MUNICIPALITY=新宿区

# Output file path (optional, auto-generated if omitted)
# SCRAPER_OUTPUT=output/result.csv

# Limit number of records (for testing, to avoid IP bans)
# SCRAPER_LIMIT=10

# API ingest mode: set both to POST results directly to the DB instead of CSV
# INGEST_API_URL=http://localhost:4030
# INGEST_API_KEY=your-secret-key-here
