{
  "permissions": {
    "allow": ["Bash(*)"],
    "bash": {
      "allow": ["*"],
      "deny": [
        "rm -rf /",
        "rm -rf ~",
        "sudo rm -rf /",
        "shutdown",
        "reboot",
        "mkfs*",
        "dd if=* of=/dev/*",
        ">: /dev/sd*",
        "chmod -R 777 /",
        "chown -R * /",
        "git clean -fdx"
      ]
    }
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["supabase"],
  "fileSystem": {
    "read": ["**"],
    "write": ["**"]
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/scripts/worktree-setup.sh",
            "timeout": 120,
            "statusMessage": "Creating worktree & setting up (env, mise, bun)..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "コード変更がない会話ならこのまま終了してください。PRを作成・更新した場合は以下を実行：\n1. git diff main...HEAD で差分全体をレビュー（バグ、ルール違反、テスト漏れ）\n2. 問題があれば gh pr review --request-changes -b '指摘内容' で投稿し、修正→コミット→プッシュ→ gh pr review --approve\n3. 問題なければ gh pr review --approve -b 'レビュー通過'"
          }
        ]
      }
    ]
  }
}
