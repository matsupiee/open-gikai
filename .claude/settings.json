{
  "permissions": {
    "allow": ["Bash(*)"],
    "bash": {
      "allow": ["*"],
      "deny": [
        "rm -rf /",
        "rm -rf ~",
        "sudo rm -rf /",
        "shutdown",
        "reboot",
        "mkfs*",
        "dd if=* of=/dev/*",
        ">: /dev/sd*",
        "chmod -R 777 /",
        "chown -R * /",
        "git clean -fdx"
      ]
    }
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["supabase"],
  "fileSystem": {
    "read": ["**"],
    "write": ["**"]
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/scripts/worktree-setup.sh",
            "timeout": 120,
            "statusMessage": "Creating worktree & setting up (env, mise, bun)..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "agent",
            "prompt": "Evaluate if Claude made PR: $ARGUMENTS. If so, post review comment to the PR, fix, verify behavior and merge it.",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
