{
  "permissions": {
    "allow": ["Bash(*)"],
    "bash": {
      "allow": ["*"],
      "deny": [
        "rm -rf /",
        "rm -rf ~",
        "sudo rm -rf /",
        "shutdown",
        "reboot",
        "mkfs*",
        "dd if=* of=/dev/*",
        ">: /dev/sd*",
        "chmod -R 777 /",
        "chown -R * /",
        "git clean -fdx"
      ]
    }
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["supabase"],
  "fileSystem": {
    "read": ["**"],
    "write": ["**"]
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "MAIN_REPO=$(git worktree list --porcelain | head -1 | sed 's/^worktree //') && [ -f \"$MAIN_REPO/.env.local\" ] && cp \"$MAIN_REPO/.env.local\" .env.local; mise trust && bun install",
            "timeout": 120,
            "statusMessage": "Setting up worktree (mise trust & bun install)..."
          }
        ]
      }
    ]
  }
}
