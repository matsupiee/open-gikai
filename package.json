{
  "name": "open-gikai",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/node": "^22.13.14",
      "@orpc/server": "^1.12.2",
      "@orpc/client": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "^1.4.18"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:stop": "sh -c 'lsof -t -i :$0 | xargs kill -9 2>/dev/null || true'",
    "db:start": "turbo -F @open-gikai/db db:start",
    "db:stop": "turbo -F @open-gikai/db db:stop",
    "db:studio": "turbo -F @open-gikai/db db:studio",
    "db:generate": "turbo -F @open-gikai/db db:generate",
    "db:migrate": "turbo -F @open-gikai/db db:migrate",
    "db:seed": "turbo -F @open-gikai/db db:seed",
    "db:seed-municipality": "turbo -F @open-gikai/db db:seed-municipality",
    "test": "turbo test",
    "check": "oxlint && oxfmt --write",
    "scrape:local": "turbo -F @open-gikai/scraper-worker scrape:local"
  },
  "dependencies": {
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251213.0",
    "@open-gikai/config": "workspace:*",
    "@types/node": "catalog:",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.10"
}
